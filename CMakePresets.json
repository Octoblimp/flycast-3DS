{
    "version": 3,
    "configurePresets": [
        {
            "name": "3ds-devkitpro",
            "displayName": "Nintendo 3DS (devkitPro/MSYS2)",
            "generator": "Ninja",
            "binaryDir": "build-3ds",
            "toolchainFile": "$env{DEVKITPRO}/cmake/3DS.cmake",
            "cacheVariables": {
                "NINTENDO_3DS": "ON",
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_INSTALL_PREFIX": "artifact"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "3ds-devkitpro",
            "configurePreset": "3ds-devkitpro",
            "targets": [
                "install"
            ]
        }
    ]
}
